<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.16">
  <POU Name="Alarmes" Id="{5562c3ff-050d-45e4-aefc-859d749a3fa5}" SpecialFunc="None">
    <Declaration><![CDATA[PROGRAM Alarmes
VAR
	NB_ALARMES_MAX      : UINT := 100;
    GA_Alarmes        	: ARRAY[1..2, 1..100] OF ST_Alarmes;
    GA_AlarmesActives 	: ARRAY[1..2, 1..100] OF ST_Alarmes;
	Tab_Alarme_FREN		: ARRAY[1..2, 1..100] OF STRING(80);
    G_NbAlarmesActives  : UINT := 0;
	
	i         : UINT;
    idx       : UINT 	:= 0;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[//////////////////////////////////////////////////////////////
// gestion des alarmes (bilingue FR/EN)                     //
//////////////////////////////////////////////////////////////
//Déclaration des alarmes
//Alarme 1
GA_Alarmes[1, 1].Id := 1;
GA_Alarmes[1, 1].Libelle := 'Défaut débordement de la douche / à réarmer';
GA_Alarmes[2, 1].Libelle := 'High water level in shower tray detected / must be acquit !';
GA_Alarmes[1, 1].Active := Defaut_Debordement_Douche;

//Alarme 2
GA_Alarmes[1, 2].Id := 2;
GA_Alarmes[1, 2].Libelle := 'Défaut débordement du lavabo / à réarmer';
GA_Alarmes[2, 2].Libelle := 'High water level in sink tray detected / must be acquit !';
GA_Alarmes[1, 2].Active := Defaut_Debordement_Lavabo;

//Alarme 3
GA_Alarmes[1, 3].Id := 3;
GA_Alarmes[1, 3].Libelle := 'Défaut discordance débit d’eau de la douche / à réarmer';
GA_Alarmes[2, 3].Libelle := 'Mismatch in shower water flow rate / must be acquit !';
GA_Alarmes[1, 3].Active := Defaut_Discord_Deb_Eau_Douche;

//Alarme 4
GA_Alarmes[1, 4].Id := 4;
GA_Alarmes[1, 4].Libelle := 'Défaut discordance débit d’eau du lavabo / à réarmer';
GA_Alarmes[2, 4].Libelle := 'Mismatch in sink water flow rate / must be acquit !';
GA_Alarmes[1, 4].Active := Defaut_Discord_Deb_Eau_Lavabo;

//Alarme 5
GA_Alarmes[1, 5].Id := 5;
GA_Alarmes[1, 5].Libelle := 'Défaut discordance prise de courant / à réarmer';
GA_Alarmes[2, 5].Libelle := 'Power plug supply mismatch / must be acquit !';
GA_Alarmes[1, 5].Active := Defaut_Discord_PC_Cab;

//Alarme 6
GA_Alarmes[1, 6].Id := 6;
GA_Alarmes[1, 6].Libelle := 'Défaut prise forcée manuellement / à réarmer';
GA_Alarmes[2, 6].Libelle := 'Manually forced power plug / must be acquit !';
GA_Alarmes[1, 6].Active := Def_Discord_Alim_Prise;

//Alarme 7
GA_Alarmes[1, 7].Id := 7;
GA_Alarmes[1, 7].Libelle := 'Défaut prise lors de l’ouverture porte / à réarmer';
GA_Alarmes[2, 7].Libelle := 'Door open during a power plug cycle / must be acquit !';
GA_Alarmes[1, 7].Active := Def_Prise_Porte_Ouverte;

//Alarme 8
GA_Alarmes[1, 8].Id := 8;
GA_Alarmes[1, 8].Libelle := 'Défaut pompe de relevage / à réarmer';
GA_Alarmes[2, 8].Libelle := 'Error on the lifting pump / must be acquit !';
GA_Alarmes[1, 8].Active := Defaut_Pompe_Relevage;

//Alarme 9
GA_Alarmes[1, 9].Id := 9;
GA_Alarmes[1, 9].Libelle := 'Défaut porte ouverte depuis plus d une minute';
GA_Alarmes[2, 9].Libelle := 'Door open for more than one minute';
GA_Alarmes[1, 9].Active := Defaut_Porte_Ouverte;

//Alarme 10
GA_Alarmes[1, 10].Id := 10;
GA_Alarmes[1, 10].Libelle := 'Défaut de communication avec la passerelle LED';
GA_Alarmes[2, 10].Libelle := 'Light gateway communication error';
GA_Alarmes[1, 10].Active := Defaut_Com_Dalcnet;

//Alarme 11
GA_Alarmes[1, 11].Id := 11;
GA_Alarmes[1, 11].Libelle := 'Défaut de communication avec la vanne thermostatique de la cabine';
GA_Alarmes[2, 11].Libelle := 'thermostatic valve gateway communication error';
GA_Alarmes[1, 11].Active := Defaut_Com_Vanne_General;

//Alarme 12
GA_Alarmes[1, 12].Id := 12;
GA_Alarmes[1, 12].Libelle := 'Défaut de communication avec la vanne thermostatique générale';
GA_Alarmes[2, 12].Libelle := 'thermostatic valve gateway communication error';
GA_Alarmes[1, 12].Active := Defaut_Com_Vanne_General;

//Alarme 13
GA_Alarmes[1, 13].Id := 13;
GA_Alarmes[1, 13].Libelle := 'Défaut de communication avec l’automate maitre';
GA_Alarmes[2, 13].Libelle := 'Master PLC communication error';
GA_Alarmes[1, 13].Active := Defaut_Com_Client;

//Alarme 14
GA_Alarmes[1, 14].Id := 14;
GA_Alarmes[1, 14].Libelle := 'Discordance ouverture de la vanne de vidange de la douche';
GA_Alarmes[2, 14].Libelle := 'Water drain shower valve fault - not opened';
GA_Alarmes[1, 14].Active := Defaut_Discord_Vanne_Vid_Douche_Ouv;

//Alarme 15
GA_Alarmes[1, 15].Id := 15;
GA_Alarmes[1, 15].Libelle := 'Discordance fermeture de la vanne de vidange de la douche';
GA_Alarmes[2, 15].Libelle := 'Water drain shower valve fault - not closed';
GA_Alarmes[1, 15].Active := Defaut_Discord_Vanne_Vid_Douche_Ferm;

//Alarme 16
GA_Alarmes[1, 16].Id := 16;
GA_Alarmes[1, 16].Libelle := 'Discordance ouverture de la vanne de vidange du lavabo';
GA_Alarmes[2, 16].Libelle := 'Water drain sink valve fault - not opened';
GA_Alarmes[1, 16].Active := Defaut_Discord_Vanne_Vid_Lavabo_Ouv;

//Alarme 17
GA_Alarmes[1, 17].Id := 17;
GA_Alarmes[1, 17].Libelle := 'Discordance fermeture de la vanne de vidange du lavabo';
GA_Alarmes[2, 17].Libelle := 'Water drain sink valve fault - not closed';
GA_Alarmes[1, 17].Active := Defaut_Discord_Vanne_Vid_Lavabo_Ferm;

//Alarme 18
GA_Alarmes[1, 18].Id := 18;
GA_Alarmes[1, 18].Libelle := 'Discordance ouverture de la vanne d’alimentation de la douche';
GA_Alarmes[2, 18].Libelle := 'Water supply shower valve fault - not opened';
GA_Alarmes[1, 18].Active := Defaut_Discord_Vanne_Alim_Douche_Ouv;

//Alarme 19
GA_Alarmes[1, 19].Id := 19;
GA_Alarmes[1, 19].Libelle := 'Discordance fermeture de la vanne d alimentation de la douche';
GA_Alarmes[2, 19].Libelle := 'Water supply shower valve fault - not closed';
GA_Alarmes[1, 19].Active := Defaut_Discord_Vanne_Alim_Douche_Ferm;

//Alarme 20
GA_Alarmes[1, 20].Id := 20;
GA_Alarmes[1, 20].Libelle := 'Discordance ouverture de la vanne d’alimentation du lavabo';
GA_Alarmes[2, 20].Libelle := 'Water supply sink valve fault - not opened';
GA_Alarmes[1, 20].Active := Defaut_Discord_Vanne_Alim_Lavabo_Ouv;

//Alarme 21
GA_Alarmes[1, 21].Id := 21;
GA_Alarmes[1, 21].Libelle := 'Discordance fermeture de la vanne d’alimentation du lavabo';
GA_Alarmes[2, 21].Libelle := 'Water supply sink valve fault - not closed';
GA_Alarmes[1, 21].Active := Defaut_Discord_Vanne_Alim_Lavabo_Ferm;

//Alarme 22
GA_Alarmes[1, 22].Id := 22;
GA_Alarmes[1, 22].Libelle := 'Discordance ouverture de la vanne d’alimentation de la douchette';
GA_Alarmes[2, 22].Libelle := 'Water supply handspray valve fault - not opened';
GA_Alarmes[1, 22].Active := Defaut_Discord_Vanne_Alim_Douchette_Ouv;

//Alarme 23
GA_Alarmes[1, 23].Id := 23;
GA_Alarmes[1, 23].Libelle := 'Discordance fermeture de la vanne d’alimentation de la douchette';
GA_Alarmes[2, 23].Libelle := 'Water supply handspray valve fault - not closed';
GA_Alarmes[1, 23].Active := Defaut_Discord_Vanne_Alim_Douchette_Ferm;

//Alarme 24
GA_Alarmes[1, 24].Id := 24;
GA_Alarmes[1, 24].Libelle := 'Discordance ouverture vanne alimentation NEP';
GA_Alarmes[2, 24].Libelle := 'Mismatch between CIP supply valve opening';
GA_Alarmes[1, 24].Active := Defaut_Discord_Vanne_Alim_NEP_Ouv;

//Alarme 25
GA_Alarmes[1, 25].Id := 25;
