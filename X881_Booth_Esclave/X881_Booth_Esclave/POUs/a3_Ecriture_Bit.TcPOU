EF_Vanne_Souf_Bas_Deb :=			EF_Vanne_Souf_Bas_Deb;
EF_Vanne_Ext_Bas_Deb :=				EF_Vanne_Ext_Bas_Deb;
EF_Cons_Reg_Etanche_Ext :=			EF_Cons_Reg_Etanche_Ext;
EF_Cmd_Reg_Etanche_Souf :=			EF_Cmd_Reg_Etanche_Souf;
EF_Cons_V3V_Eau_Mitig :=			EF_Cons_V3V_Eau_Mitig;
EF_Vanne_Alim_NEP :=				EF_Vanne_Alim_NEP;
EF_Cons_V3V_Bat_Froid_CTA := 		EF_Cons_V3V_Bat_Froid_CTA;
EF_Cmd_Verin_WC_GV := 				EF_Cmd_Verin_WC_GV;
