(**********************************************Variable Ecr_Bit_Cmd_IHM5*) (*Adresse Modbus GTC : 21003*)
(*Gestion des forçages*)
EF_Cmd_PC_Cab := 					EF_Cmd_PC_Cab;
EF_Cmd_Vanne_Alim_Douche := 		EF_Cmd_Vanne_Alim_Douche;
EF_Cmd_Vanne_Alim_Douchette := 		EF_Cmd_Vanne_Alim_Douchette;
EF_Cmd_Vanne_Alim_Lavabo := 		EF_Cmd_Vanne_Alim_Lavabo;
EF_Cmd_Vanne_Vid_Douche := 			EF_Cmd_Vanne_Vid_Douche;
EF_Cmd_Vanne_Vid_Lavabo :=			EF_Cmd_Vanne_Vid_Lavabo;
