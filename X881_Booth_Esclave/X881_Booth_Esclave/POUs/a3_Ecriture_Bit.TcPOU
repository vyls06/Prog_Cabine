<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.15">
  <POU Name="a3_Ecriture_Bit" Id="{cfd51b1b-7ad0-45cb-b8d7-314658a28fe1}" SpecialFunc="None">
    <Declaration><![CDATA[PROGRAM a3_Ecriture_Bit
VAR
	TP_RAZ_Marche_Manu: TP;
	TP_RAZ_Stop_Manu: TP;
	TP_RAZ_Depollution: TP;
	TP_RAZ_Valid: TP;
	TP_RAZ_Pause: TP;
	TP_RAZ_Valid_Recette: TP;
	TP_RAZ_Marche_Auto: TP;
	TP_RAZ_Stop_Auto: TP;
	TP_RAZ_Rearm: TP;
	TP_RAZ_Enr_Recette: TP;
	TP_RAZ_MAL: TP;
	TP_RAZ_FWCGV: TP;
	TP_RAZ_FWCPV: TP;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[(**********************************************Gestion des RAZ des Bits d'écriture de l'IHM et GTC*)
TP_RAZ_Marche_Manu(IN:= %MX17422.0, PT:= T#1S);
%MX17422.0 := (SEL(%MX17422.0, %MX17422.0, FALSE) OR TP_RAZ_Marche_Manu.Q);

TP_RAZ_Stop_Manu(IN:= %MX17422.1, PT:= T#1s);
%MX17422.1 := (SEL(%MX17422.1, %MX17422.1, FALSE) OR TP_RAZ_Stop_Manu.Q);

TP_RAZ_Depollution(IN:= %MX17422.2, PT:= T#1s);
%MX17422.2 := (SEL(%MX17422.2, %MX17422.2, FALSE) OR TP_RAZ_Depollution.Q);

TP_RAZ_Valid(IN:= %MX17422.6, PT:= T#2s);
%MX17422.6 := (SEL(%MX17422.6, %MX17422.6, FALSE) OR TP_RAZ_Valid.Q);

TP_RAZ_Pause(IN:= %MX17422.7, PT:= T#1s);
%MX17422.7 := (SEL(%MX17422.7, %MX17422.7, FALSE) OR TP_RAZ_Pause.Q);

TP_RAZ_Valid_Recette(IN:= %MX17422.9, PT:= T#5s);
%MX17422.9 := (SEL(%MX17422.9, %MX17422.9, FALSE) OR TP_RAZ_Valid_Recette.Q);

TP_RAZ_Marche_Auto(IN:= %MX17422.10, PT:= T#5s);
%MX17422.10 := (SEL(%MX17422.10, %MX17422.10, FALSE) OR TP_RAZ_Marche_Auto.Q);

TP_RAZ_Stop_Auto(IN:= %MX17422.11, PT:= T#1s);
%MX17422.11 := (SEL(%MX17422.11, %MX17422.11, FALSE) OR TP_RAZ_Stop_Auto.Q);

TP_RAZ_Rearm(IN:= %MX17422.12, PT:= T#1s);
%MX17422.12 := (SEL(%MX17422.12, %MX17422.12, FALSE) OR TP_RAZ_Rearm.Q);

TP_RAZ_Enr_Recette(IN:= %MX17422.13, PT:= T#5s);
%MX17422.13 := (SEL(%MX17422.13, %MX17422.13, FALSE) OR TP_RAZ_Enr_Recette.Q);

TP_RAZ_MAL(IN:= %MX17434.7, PT:= T#1S);
%MX17434.7 := (SEL(%MX17434.7, %MX17434.7, FALSE) OR TP_RAZ_MAL.Q);

TP_RAZ_FWCGV(IN:= %MX17438.2, PT:= T#2S);
%MX17438.2 := (SEL(%MX17438.2, %MX17438.2, FALSE) OR TP_RAZ_FWCGV.Q);

TP_RAZ_FWCPV(IN:= %MX17438.4, PT:= T#2s);
%MX17438.4 := (SEL(%MX17438.4, %MX17438.4, FALSE) OR TP_RAZ_FWCPV.Q);

(**********************************************Variable Ecr_Bit_Cmd_IHM1*) (*Adresse Modbus GTC : 20999*)
(*Bit ecriture gestion recette*)
Start_Mode_Manu := 					Start_Mode_Manu; (*Impultion*)
Reset_Mode_Manu := 					Reset_Mode_Manu; (*Impultion*)
Start_Etat_Depollution := 			Start_Etat_Depollution; (*Impultion*)
