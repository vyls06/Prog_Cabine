                <v n="VisualElementName">"Button"</v>
                <v n="VisualElementTypeName">"VisuFbElemButton"</v>
                <v n="VisualElementIsRectangle">true</v>
                <v n="VisualElementIdentifier">"GenElemInst_72"</v>
                <n n="VisualElementOfflinePaintCommands" />
                <n n="VisualElementFrameInformation" />
                <d n="VisualElementInputActions" t="Hashtable" ckt="String" cvt="STSnippetInputAction[]">
                  <v>OnMouseDown</v>
                  <a cet="STSnippetInputAction">
                    <o>
                      <v n="STSnippet">"IF (Option_Douche OR Option_Lavabo)
	THEN
	VisuElems.CURRENTVISU := 'Maintenance_2';
	ELSIF (Option_Bas_Debit OR Option_Douchette OR Option_NEP)
		THEN
		VisuElems.CURRENTVISU := 'Maintenance_3';
	ELSIF (Option_WC_GV OR Option_WC_PV OR Option_Prise)
		THEN
		VisuElems.CURRENTVISU := 'Maintenance_4';
	ELSIF (Option_Cabine_Climatique)
		THEN
		VisuElems.CURRENTVISU := 'Maintenance_5';
	ELSIF (Option_Com_RegSouf_Ultrason)
		THEN
		VisuElems.CURRENTVISU := 'Maintenance_6';
	ELSE
		VisuElems.CURRENTVISU := 'Maintenance_7';
END_IF"</v>
                    </o>
                  </a>
                </d>
                <v n="VisualElementIdentification">{266ed9e8-e142-432f-a55d-ba5047b32c10}</v>
