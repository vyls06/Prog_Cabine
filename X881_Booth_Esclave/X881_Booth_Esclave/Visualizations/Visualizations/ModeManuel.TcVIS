                <d n="VisualElementInputActions" t="Hashtable" ckt="String" cvt="STSnippetInputAction[]">
                  <v>OnMouseDown</v>
                  <a cet="STSnippetInputAction">
                    <o>
                      <v n="STSnippet">"Manu_Choix_Numero_Mode := Manu_Choix_Numero_Mode + 1;

GVL_Visu.Manu_j := 0;

FOR GVL_Visu.Manu_j := 0 TO 29 BY 1 DO
	IF (NOT (GVL_Visu.Tab_Choix_Modes[GVL_Visu.Manu_j]) AND (Manu_Choix_Numero_Mode = GVL_Visu.Manu_j))
		THEN
		Manu_Choix_Numero_Mode := Manu_Choix_Numero_Mode + 1;
	END_IF
END_FOR

IF (Manu_Choix_Numero_Mode &gt; GVL_Visu.Max_Mode_Manu)
	THEN
	Manu_Choix_Numero_Mode := GVL_Visu.Max_Mode_Manu;
END_IF"</v>
                    </o>
                  </a>
                </d>
