                <d n="VisualElementInputActions" t="Hashtable" ckt="String" cvt="STSnippetInputAction[]">
                  <v>OnMouseDown</v>
                  <a cet="STSnippetInputAction">
                    <o>
                      <v n="STSnippet">"Manu_Choix_Numero_Mode := Manu_Choix_Numero_Mode - 1;

IF (Manu_Choix_Numero_Mode &lt; GVL_Visu.Min_Mode_Manu)
	THEN
	Manu_Choix_Numero_Mode := GVL_Visu.Min_Mode_Manu;
END_IF

GVL_Visu.Manu_i := 30;

FOR GVL_Visu.Manu_i := 30 TO 0 BY -1 DO
	IF ((NOT GVL_Visu.Tab_Choix_Modes[GVL_Visu.Manu_i]) AND (Manu_Choix_Numero_Mode = GVL_Visu.Manu_i))
		THEN
		Manu_Choix_Numero_Mode := Manu_Choix_Numero_Mode - 1;
	END_IF
END_FOR"</v>
                    </o>
                  </a>
                </d>
